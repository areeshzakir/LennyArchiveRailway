{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npx prisma generate && npx tsc --esModuleInterop"
    },
    "deploy": {
        "startCommand": "npx prisma migrate deploy && npx ts-node worker/sync.ts",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}